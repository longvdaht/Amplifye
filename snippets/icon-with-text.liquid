{% comment %}
  Renders icon with text block

  Accepts:
  - block: {Object} passes in the block information.


  Usage:
  {% render 'icon-with-text',
    block: block
  %}
{% endcomment %}
{{ 'icon-with-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_1_empty = false
  assign heading_2_empty = false
  assign heading_3_empty = false
  assign heading_4_empty = false
  assign text_only_all_items = true
  assign items_count = 0

  if block.settings.heading_1 == empty
    assign heading_1_empty = true
  else
    assign items_count = items_count | plus: 1
  endif

  if block.settings.heading_2 == empty
    assign heading_2_empty = true
  else
    assign items_count = items_count | plus: 1
  endif

  if block.settings.heading_3 == empty
    assign heading_3_empty = true
  else
    assign items_count = items_count | plus: 1
  endif

  if block.settings.heading_4 == empty
    assign heading_4_empty = true
  else
    assign items_count = items_count | plus: 1
  endif

  if heading_1_empty == false or block.settings.image_1 != null
    assign text_only_all_items = false
  elsif heading_2_empty == false or block.settings.image_2 != null
    assign text_only_all_items = false
  elsif heading_3_empty == false or block.settings.image_3 != null
    assign text_only_all_items = false
  elsif heading_4_empty == false or block.settings.image_4 != null
    assign text_only_all_items = false
  endif
-%}
<ul
  class="custom items-{{ items_count }}-wrappers icon-with-text icon-with-text--{{ block.settings.layout }} list-unstyled{% if text_only_all_items %} icon-with-text--text-only{% endif %}"
  {{ block.shopify_attributes }}
>
  {%- unless heading_1_empty -%}
    <li class="icon-with-text__item {% if block.settings.use_app_embeded_1 %}app-embed-1{% endif %}">
        <img
          src="{{ block.settings.image_1 | image_url }}"
          {% if block.settings.image_1.alt != blank %}
            alt="{{ block.settings.image_1.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="{{ block.settings.image_1.height }}"
          width="{{ block.settings.image_1.width }}"
          loading="lazy"
        >
      <span class="h4 inline-richtext t-l-3">
        {{- block.settings.heading_1 -}}
      </span>
    </li>
  {%- endunless -%}
  {%- unless heading_2_empty -%}
    <li class="icon-with-text__item {% if block.settings.use_app_embeded_2 %}app-embed-2{% endif %}">
        <img
          src="{{ block.settings.image_2 | image_url }}"
          {% if block.settings.image_2.alt != blank %}
            alt="{{ block.settings.image_2.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="{{ block.settings.image_2.height }}"
          width="{{ block.settings.image_2.width }}"
          loading="lazy"
        >
      <span class="h4 inline-richtext t-l-3">
        {{- block.settings.heading_2 -}}
      </span>
    </li>
  {%- endunless -%}
  {%- unless heading_3_empty -%}
    <li class="icon-with-text__item {% if block.settings.use_app_embeded_3 %}app-embed-3{% endif %}">
        <img
          src="{{ block.settings.image_3 | image_url }}"
          {% if block.settings.image_3.alt != blank %}
            alt="{{ block.settings.image_3.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="{{ block.settings.image_3.height }}"
          width="{{ block.settings.image_3.width }}"
          loading="lazy"
        >
      <span class="h4 inline-richtext t-l-3">
        {{- block.settings.heading_3 -}}
      </span>
    </li>
  {%- endunless -%}
  {%- unless heading_4_empty -%}
    <li class="icon-with-text__item {% if block.settings.use_app_embeded_4 %}app-embed-4{% endif %}">
        <img
          src="{{ block.settings.image_4 | image_url }}"
          {% if block.settings.image_4.alt != blank %}
            alt="{{ block.settings.image_4.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="{{ block.settings.image_4.height }}"
          width="{{ block.settings.image_4.width }}"
          loading="lazy"
        >
      <span class="h4 inline-richtext t-l-3">
        {{- block.settings.heading_4 -}}
      </span>
    </li>
  {%- endunless -%}
</ul>
<script>
  (function () {
    var FLEX_SELECTOR = '.shopify-app-block[id*="flex_badge"]';

    function moveFlexIntoSlot() {
      var flexBlock = document.querySelector(FLEX_SELECTOR);
      if (!flexBlock) return false;

      // Find first icon-with-text item that opts in via app-embed-* class
      var slot = document.querySelector(
        '.icon-with-text__item.app-embed-1, '
        + '.icon-with-text__item.app-embed-2, '
        + '.icon-with-text__item.app-embed-3, '
        + '.icon-with-text__item.app-embed-4'
      );
      if (!slot) return false;

      // Already moved
      if (slot.contains(flexBlock)) return true;

      slot.appendChild(flexBlock);
      slot.classList.add('has-app-embed');
      return true;
    }

    function init() {
      if (moveFlexIntoSlot()) return;

      // Flex may load async — observe until it appears
      var observer = new MutationObserver(function () {
        if (moveFlexIntoSlot()) observer.disconnect();
      });
      observer.observe(document.body, { childList: true, subtree: true });
      setTimeout(function () { observer.disconnect(); }, 10000);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Theme editor re-render support
    document.addEventListener('shopify:section:load',    init);
    document.addEventListener('shopify:section:reorder', init);
    document.addEventListener('shopify:block:select',    init);
  })();
</script>