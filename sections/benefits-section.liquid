{% comment %}
  Section: Benefits
  - Separate background images for desktop and mobile
  - Separate product images for desktop and mobile
  - Desktop: 2 columns — left: benefits list, right: product image
  - Mobile: vertical — heading > product image > benefits list
{% endcomment %}
{{ 'benefit-pdp.css' | asset_url | stylesheet_tag }}

<section class="benefits" id="benefits-{{ section.id }}">

  {% comment %} Background images {% endcomment %}
  <div class="benefits__bg">
    {% if section.settings.background_image_desktop != blank %}
      <div class="benefits__bg-img benefits__bg-img--desktop">
        {{ section.settings.background_image_desktop | image_url: width: 1800 | image_tag:
          loading: 'lazy',
          widths: '1100, 1400, 1800',
          sizes: '100vw',
          alt: section.settings.background_image_desktop.alt | escape
        }}
      </div>
    {% endif %}

    {% if section.settings.background_image_mobile != blank %}
      <div class="benefits__bg-img benefits__bg-img--mobile">
        {{ section.settings.background_image_mobile | image_url: width: 800 | image_tag:
          loading: 'lazy',
          widths: '400, 600, 800',
          sizes: '100vw',
          alt: section.settings.background_image_mobile.alt | escape
        }}
      </div>
    {% elsif section.settings.background_image_desktop != blank %}
      <div class="benefits__bg-img benefits__bg-img--mobile">
        {{ section.settings.background_image_desktop | image_url: width: 800 | image_tag:
          loading: 'lazy',
          widths: '400, 600, 800',
          sizes: '100vw',
          alt: section.settings.background_image_desktop.alt | escape
        }}
      </div>
    {% endif %}
  </div>

  <div class="benefits__inner">
    {% comment %} Heading {% endcomment %}
    {% if section.settings.heading != blank %}
      <h2 class="benefits__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="content-wrapper">
    {% comment %} Mobile product image — shown between heading and list {% endcomment %}
    <div class="benefits__product-image benefits__product-image--mobile">
      {% if section.settings.product_image_mobile != blank %}
        {{ section.settings.product_image_mobile | image_url: width: 600 | image_tag:
          loading: 'lazy',
          widths: '300, 400, 600',
          sizes: '100vw',
          alt: section.settings.product_image_mobile.alt | escape
        }}
      {% elsif section.settings.product_image_desktop != blank %}
        {{ section.settings.product_image_desktop | image_url: width: 600 | image_tag:
          loading: 'lazy',
          widths: '300, 400, 600',
          sizes: '100vw',
          alt: section.settings.product_image_desktop.alt | escape
        }}
      {% endif %}
    </div>

    {% comment %} Main content grid {% endcomment %}
    <div class="benefits__grid">

      {% comment %} Left column: benefits list {% endcomment %}
      <div class="benefits__list-col">
        <div class="benefits__list">
          {% for block in section.blocks %}
            {% if block.type == 'benefit_item' %}
              <div class="benefits__item" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <h3 class="benefits__item-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="benefits__item-desc">{{ block.settings.description }}</p>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="benefits__product-image benefits__product-image--desktop">
        {% if section.settings.product_image_desktop != blank %}
          {{ section.settings.product_image_desktop | image_url: width: 800 | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800',
            sizes: '50vw',
            alt: section.settings.product_image_desktop.alt | escape
          }}
        {% endif %}
      </div>

    </div>
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "tag": "section",
  "class": "section-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits you can feel."
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image (Mobile)",
      "info": "Falls back to desktop image if left empty"
    },
    {
      "type": "header",
      "content": "Product Image"
    },
    {
      "type": "image_picker",
      "id": "product_image_desktop",
      "label": "Product Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "product_image_mobile",
      "label": "Product Image (Mobile)",
      "info": "Falls back to desktop image if left empty"
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "Benefit Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Deeper Sleep"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Key amino acids from protein help you get sleep that's actually restful."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "settings": {
        "heading": "Benefits you can feel."
      },
      "blocks": [
        {
          "type": "benefit_item",
          "settings": {
            "title": "Deeper Sleep",
            "description": "Key amino acids from protein help you get sleep that's actually restful."
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "title": "All-Day Energy",
            "description": "Better protein absorption means steadier energy from morning to night."
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "title": "Stronger Muscles",
            "description": "More amino acids absorbed helps you build and maintain strength."
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "title": "Smoother Digestion",
            "description": "Better protein breakdown improves gut comfort and digestion."
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "title": "Sharper Clarity",
            "description": "The amino acids in protein keep your focus sharp and your mind clear."
          }
        }
      ]
    }
  ]
}
{% endschema %}
