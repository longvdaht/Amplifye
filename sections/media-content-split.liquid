{% comment %}
  Section: Media Content Split
  - Image or Video on left/right
  - Supports stats badges (pill with number + text)
  - Responsive: side-by-side on desktop, stacked on mobile
{% endcomment %}
{{ 'media-content-split.css' | asset_url | stylesheet_tag }}

{%- liquid
	assign button_style = section.settings.button_style
-%}
{% style %}
  .mcs-content .mcs-eyebrow:before {
    background: {{ section.settings.dot_color }};
  }
{% endstyle %}
<section class="mcs-section" id="mcs-{{ section.id }}">
  <div class="mcs-container" style="background-color: {{ section.settings.bg_color }}";>
    <div class="mcs-card media-{{ section.settings.media_position }}">

      {%- comment -%} ── MEDIA COLUMN ── {%- endcomment -%}
      <div class="mcs-media">
        {%- if section.settings.media_type == 'video' and section.settings.video != blank -%}
          {{-
            section.settings.video
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              playsinline: true
          -}}
        {%- elsif section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            class="image desktop-only"
          >
          {% if section.settings.image_mobile != blank -%}
            <img
              src="{{ section.settings.image_mobile | image_url: width: 900 }}"
              alt="{{ section.settings.image_mobile.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image_mobile.width }}"
              height="{{ section.settings.image_mobile.height }}"
              class="image mobile-only"
            >
          {% endif -%} 
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'mcs-placeholder-svg' }}
        {%- endif -%}
        {%- if section.settings.source_text != blank -%}
          <div class="note-source mobile-only">
            {{ section.settings.source_text }}
          </div>
        {%- endif -%}
        {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
          {%- liquid
            if button_style == 'secondary'
              assign btn_class = ' cr-orange'
            else
              assign btn_class = ' hover-white'
            endif
          -%}
          <div class="mcs-cta-wrap mobile-only">
            <a class="mcs-cta-btn btn {{ btn_class }}" href="{{ section.settings.btn_url }}">
              {{ section.settings.btn_label }}
              <span class="mcs-cta-btn-icon" aria-hidden="true"></span>
            </a>
            {%- if section.settings.btn_subtext != blank -%}
              <span class="mcs-cta-sub">{{ section.settings.btn_subtext }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── CONTENT COLUMN ── {%- endcomment -%}
      <div class="mcs-content">

        {%- if section.settings.eyebrow != blank -%}
          <p class="mcs-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mcs-heading {% if section.settings.heading_larger %} larger{% endif %}">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <p class="mcs-body">{{ section.settings.body_text }}</p>
        {%- endif -%}

        {%- comment -%} Stats / Badges block {%- endcomment -%}
        {%- if section.settings.show_stats_box -%}
          <div class="mcs-stats-box">
            {%- if section.settings.stats_label != blank -%}
              <p class="mcs-stats-label">{{ section.settings.stats_label }}</p>
            {%- endif -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'stat' -%}
                <div class="mcs-stat-row" {{ block.shopify_attributes }}>
                  <span class="mcs-badge" style="background-color: {{ block.settings.bg_color }};">{{ block.settings.badge_text }}</span>
                  {%- if block.settings.description != blank -%}
                    <span class="mcs-stat-desc">{{ block.settings.description }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} CTA button {%- endcomment -%}
        {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
          {%- liquid
            if button_style == 'secondary'
              assign btn_class = ' cr-orange'
            else
              assign btn_class = ' hover-white'
            endif
          -%}
          <div class="mcs-cta-wrap desktop-only">
            <a class="mcs-cta-btn btn {{ btn_class }}" href="{{ section.settings.btn_url }}">
              {{ section.settings.btn_label }}
              <span class="mcs-cta-btn-icon" aria-hidden="true"></span>
            </a>
            {%- if section.settings.btn_subtext != blank -%}
              <span class="mcs-cta-sub">{{ section.settings.btn_subtext }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.source_text != blank -%}
          <div class="note-source desktop-only">
            {{ section.settings.source_text }}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Media Content Split",
  "tag": "section",
  "class": "media-content-split",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
			"type": "color",
			"id": "bg_color",
			"label": "Background Color",
			"default": "#FFFAF1"
		},
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-Hosted Video"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "THE PROTEIN GAP"
    },
    {
			"type": "color",
			"id": "dot_color",
			"label": "Eyebrow dot label",
			"default": "#C14B24"
		},
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Less than <em>50%</em> of the protein we eat is actually absorbed.</p>"
    },
    {
      "type": "checkbox",
      "id": "heading_larger",
      "label": "Use heading larger",
      "default": false
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Stats Box"
    },
    {
      "type": "checkbox",
      "id": "show_stats_box",
      "label": "Show stats box",
      "default": true
    },
    {
      "type": "text",
      "id": "stats_label",
      "label": "Stats box label",
      "default": "P24 increases protein's bioavailability."
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
			"type": "select",
			"id": "button_style",
			"label": "Button style",
			"options": [
				{
					"value": "primary",
					"label": "Primary hover white"
				},
				{
					"value": "secondary",
					"label": "Secondary hover black"
				},
				{
					"value": "outline",
					"label": "Outline"
				}
			],
			"default": "primary"
		},
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "btn_subtext",
      "label": "Button subtext",
      "default": "From $58.00 a month"
    },
    {
      "type": "header",
      "content": "Source Note"
    },
    {
      "type": "richtext",
      "id": "source_text",
      "label": "Source / Disclaimer"
    } 
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "2X"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "increase in the stomach"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#C14B24"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media Content Split",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "badge_text": "115%",
            "description": "increase in the stomach"
          }
        },
        {
          "type": "stat",
          "settings": {
            "badge_text": "15%",
            "description": "increase in the small intestine"
          }
        }
      ]
    }
  ]
}
{% endschema %}
