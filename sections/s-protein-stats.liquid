{% schema %}
{
	"name": "Protein Stats",
	"tag": "section",
	"class": "s-protein-stats p-x-max p-y-section bg-black cr-cream",
	"presets": [
		{
			"name": "Protein Stats",
			"settings": {
				"heading": "More from every protein on your plate.",
				"subheading": "Amplifye all protein sources: animal-based, plant-based, and powders.",
				"proteins": [
					"beef",
					"chicken",
					"tofu",
					"atlantic-salmon",
					"eggs"
				]
			}
		}
	],
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading"
		},
		{
			"metaobject_type": "proteins",
			"type": "metaobject_list",
			"id": "proteins",
			"label": "Proteins"
		}
	]
}
{% endschema %}

{%- liquid
	assign heading = section.settings.heading
	assign subheading = section.settings.subheading
	assign proteins = section.settings.proteins
-%}

{{ 'protein-stats.css' | asset_url | stylesheet_tag }}

{%- if proteins.count > 0 -%}
	{%- if heading != blank or subheading != blank -%}
		<div class="s-protein-stats__header f-v f-a-c">
			{%- if heading != blank -%}
				<h2 class="s-protein-stats__heading t-h-1">
					{{ heading }}
				</h2>
			{%- endif -%}

			{%- if subheading != blank -%}
				<p class="s-protein-stats__subheading t-l-6">
					{{ subheading }}
				</p>
			{%- endif -%}
		</div>
	{%- endif -%}

	<div class="s-protein-stats__blocks">
		{%- capture slider_html -%}
			{%- for i in proteins -%}
				{%- liquid
					assign image = i.image
					assign name = i.name
					assign feature_number = i.feature_number
					assign feature_label_bottom = i.feature_label_bottom
				-%}

				{%- if image != null -%}
					<div class="s-protein-stats__card c-slider__slide">
						<div class="s-protein-stats__card__image object-fit">
							{%- render 'c-img-srcset',
								image: image,
								alt: image.alt
							-%}
						</div>

						<div class="s-protein-stats__card__content f-v f-a-c f-j-e">
							{%- if name != blank -%}
								<p class="s-protein-stats__card__name t-l-4">
									{{ name }}
								</p>
							{%- endif -%}

							{%- if feature_number != blank -%}
								<p class="s-protein-stats__card__number t-h-1">
									{{ feature_number }}
								</p>
							{%- endif -%}

							{%- if feature_label_bottom != blank -%}
								<p class="s-protein-stats__card__label t-b-4">
									{{ feature_label_bottom }}
								</p>
							{%- endif -%}
						</div>
					</div>
				{%- endif -%}
			{%- endfor -%}
		{%- endcapture -%}

		{%- render 'c-slider',
			slider_html: slider_html,
			slider_options: "{'loop': true, 'align': 'start', 'watchDrag': true}",
			enable_nav: true,
			enable_wheel: true
		-%}
	</div>
{%- endif -%}

{% stylesheet %}
.s-protein-stats__header {
	gap: 1rem;
	margin-bottom: 3rem;
	text-align: center;
}

.s-protein-stats__heading {
	max-width: 1100px;
}

.s-protein-stats__subheading {
	max-width: 620px;
}

.s-protein-stats__blocks {
	width: 100%;
}

.s-protein-stats__card {
	position: relative;
	flex: 0 0 auto;
	width: calc((100% - 4rem) / 5);
	aspect-ratio: 3 / 5;
	overflow: hidden;
	margin-right: 1rem;
}

.s-protein-stats__card:last-child {
	margin-right: 0;
}

.s-protein-stats__card__image {
	position: absolute;
	inset: 0;
	z-index: 0;
}

.s-protein-stats__card__image img {
	width: 100%;
	height: 100%;
	object-fit: cover;
}

.s-protein-stats__card__image::after {
	content: '';
	position: absolute;
	inset: 0;
	background: linear-gradient(
		to bottom,
		rgba(0, 0, 0, 0) 40%,
		rgba(0, 0, 0, 0.55) 60%,
		rgba(0, 0, 0, 0.9) 100%
	);
	z-index: 1;
	pointer-events: none;
}

.s-protein-stats__card__content {
	position: absolute;
	bottom: 0;
	left: 0;
	right: 0;
	z-index: 2;
	padding: 1.5rem 1rem 2rem;
	gap: 0.5rem;
	text-align: center;
	color: var(--cr-cream);
}

.s-protein-stats__card__name {
	text-transform: uppercase;
	letter-spacing: 0.08em;
	margin: 0;
}

.s-protein-stats__card__number {
	margin: 0;
	line-height: 1;
}

.s-protein-stats__card__label {
	margin: 0;
	opacity: 0.88;
	max-width: 220px;
}

@media (max-width: 1200px) {
	.s-protein-stats__card {
		width: calc((100% - 3rem) / 4);
	}
}

@media (max-width: 900px) {
	.s-protein-stats__card {
		width: calc((100% - 2rem) / 3);
	}
}

@media (max-width: 600px) {
	.s-protein-stats__header {
		margin-bottom: 2rem;
	}

	.s-protein-stats__card {
		width: calc(100% / 1.6);
		aspect-ratio: 3 / 5;
	}

	.s-protein-stats__card__content {
		padding: 1.25rem 0.75rem 1.5rem;
	}
}
{% endstylesheet %}
