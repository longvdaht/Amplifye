{% schema %}
	{
		"name": "Testimonial Video",
		"tag": "section",
		"class": "m-y-section",
		"presets": [
			{
				"name": "Testimonial Video",
				"settings": {
					"layout": "vertical",
					"heading": "",
					"subheading": "See what others are saying",
					"cta_label": "See all reviews",
					"cta_url": "",
					"bg_color": "#7A2010",
					"text_color": "#F5EFE4"
				},
				"blocks": [
					{
						"type": "text_review",
						"settings": {
							"eyebrow": "ONE CAPSULE. REAL RESULTS.",
							"content": "P24 is a digestion wizard. I've always had trouble with my digestion, often experiencing bloat, brain fog and discomfort. Since taking P24 for the past two months",
							"author": "LINDSAY E."
						}
					},
					{
						"type": "block",
						"settings": {
							"title": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
							"name": "Sarah D.",
							"is_autoplay": true
						}
					},
					{
						"type": "block",
						"settings": {
							"title": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
							"name": "Sarah D.",
							"is_autoplay": true
						}
					}
				]
			}
		],
		"settings": [
			{
				"type": "select",
				"id": "layout",
				"label": "Layout",
				"options": [
					{ "value": "vertical",   "label": "Vertical" },
					{ "value": "horizontal", "label": "Horizontal" }
				]
			},
			{ "type": "checkbox", "id": "custom_style","label": "Use Landing Page Styling","default": false },
			{ "type": "text", "id": "heading",    "label": "Heading" },
			{ "type": "text", "id": "subheading", "label": "Subheading" },
			{ "type": "text", "id": "cta_label",  "label": "CTA Label", "default": "See all reviews" },
			{ "type": "url",  "id": "cta_url",    "label": "CTA URL" },
	
			{ "type": "header", "content": "Colors" },
			{ "type": "color", "id": "bg_color",   "label": "Background color", "default": "#FFFAF1" },
			{ "type": "color", "id": "text_color", "label": "Text color",       "default": "#000000" },
	
			{ "type": "header", "content": "Margin" },
			{ "type": "range", "id": "margin_top",    "label": "Top",    "min": -200, "max": 200, "step": 4, "unit": "px", "default": 0 },
			{ "type": "range", "id": "margin_bottom", "label": "Bottom", "min": -200, "max": 200, "step": 4, "unit": "px", "default": 0 },
	
			{ "type": "header", "content": "Show dots" },
			{ "type": "checkbox", "id": "show_dots", "label": "Show dots (media slider)", "default": true }
		],
		"max_blocks": 20,
		"blocks": [
			{
				"type": "text_review",
				"name": "Text Review",
				"settings": [
					{ "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "ONE CAPSULE. REAL RESULTS." },
					{ "type": "textarea", "id": "content", "label": "Review content" },
					{ "type": "text",     "id": "author",  "label": "Author" }
				]
			},
			{
				"type": "block",
				"name": "Video / Image Block",
				"settings": [
					{ "type": "image_picker", "id": "image", "label": "Image" },
					{ "type": "video",        "id": "video", "label": "Video", "info": "Recommended aspect ratio is 9:16" },
					{ "type": "textarea",     "id": "title", "label": "Paragraph", "info": "Text exceeding 60 characters will be truncated." },
					{ "type": "text",         "id": "name",  "label": "Name" },
					{
						"type": "checkbox",
						"id": "is_autoplay",
						"label": "Autoplay",
						"info": "Autoplay video will be muted",
						"visible_if": "{{ block.settings.video != blank }}",
						"default": true
					}
				]
			}
		]
	}
	{% endschema %}
	
	{% style %}
		#shopify-section-{{ section.id }}.m-y-section {
			margin-top: {{ section.settings.margin_top }}px;
			margin-bottom: {{ section.settings.margin_bottom }}px;
		}
	
		#shopify-section-{{ section.id }} .s-testimonial-video {
			background-color: {{ section.settings.bg_color }};
			color: {{ section.settings.text_color }};
		}
	
		{% unless section.settings.show_dots %}
			#shopify-section-{{ section.id }} .s-testimonial-video__blocks .c-slider__dots {
				display: none;
			}
		{% endunless %}
	{% endstyle %}

	{{ 'testimonial-custom.css' | asset_url | stylesheet_tag }}

	{% liquid
		assign layout = section.settings.layout
		assign heading = section.settings.heading
		assign subheading = section.settings.subheading
		assign cta_label = section.settings.cta_label
		assign cta_url = section.settings.cta_url
	
		assign text_reviews = section.blocks | where: 'type', 'text_review'
		assign media_blocks = section.blocks | where: 'type', 'block'
	
		if media_blocks.size < 5
			assign count_item = 'less-items'
		endif
	%}
	
	{% if section.blocks.size > 0 %}
		<div
			class="s-testimonial-video {% if layout == 'vertical' %}is-vertical f-v f-a-s{% else %}is-horizontal f-h{% endif %} {{ count_item }} {% if section.settings.custom_style %}custom-style{% endif %}"
		>
			{%- comment -%} ========== OPTIONAL HEADER ========== {%- endcomment -%}
			{%- if heading != blank or subheading != blank or cta_label != blank -%}
				<div class="s-testimonial-video__header p-x-max">
					<h2 class="s-testimonial-video__heading t-h-3">{{ heading }}</h2>
					<p class="s-testimonial-video__subheading t-l-5">{{ subheading }}</p>
	
					{%- if cta_label != blank and cta_url != blank -%}
						<a
							class="s-testimonial-video__cta btn-outline tablet-up-only"
							href="{{- cta_url -}}"
						>
							<span class="btn-outline__label">{{- cta_label -}}</span>
						</a>
					{%- endif -%}
				</div>
			{%- endif -%}
	
			{%- comment -%} ========== TEXT REVIEW SLIDER ========== {%- endcomment -%}
			{%- if text_reviews.size > 0 -%}
				<div class="s-testimonial-video__reviews">
					{%- capture text_slider_html -%}
						{%- for block in text_reviews -%}
							{%- liquid
								assign eyebrow = block.settings.eyebrow
								assign content = block.settings.content
								assign author  = block.settings.author
							-%}
							<div class="c-slider__slide s-testimonial-video__review" {{ block.shopify_attributes }}>
								<div class="s-testimonial-video__review-inner">
									{%- if eyebrow != blank -%}
										<p class="s-testimonial-video__review-eyebrow">{{ eyebrow }}</p>
									{%- endif -%}
									{%- if content != blank -%}
										<blockquote class="s-testimonial-video__review-quote">
											{{ content }}
										</blockquote>
									{%- endif -%}
									{%- if author != blank -%}
										<cite class="s-testimonial-video__review-author">— {{ author }}</cite>
									{%- endif -%}
								</div>
							</div>
						{%- endfor -%}
					{%- endcapture -%}
	
					{%- render 'c-slider',
						classes: 's-testimonial-video__reviews-slider',
						slider_html: text_slider_html,
						slider_options: "{'loop': true, 'skipSnaps': false, 'align': 'center', 'watchDrag': true}",
						is_full_width_on_mobile: true,
						enable_nav: false,
						enable_dots: true
					-%}
				</div>
			{%- endif -%}
	
			{%- comment -%} ========== MEDIA CAROUSEL (video / image) ========== {%- endcomment -%}
			{%- if media_blocks.size > 0 -%}
				{%- capture slider_html -%}
					{% for block in media_blocks %}
						{% liquid
							assign video = block.settings.video
							assign image = block.settings.image
							assign content = block.settings.title
							assign name = block.settings.name
							assign is_autoplay = block.settings.is_autoplay
							if is_autoplay == true
								assign show_btns = false
							else
								assign show_btns = true
							endif
	
							if video != null
								assign selected_media_type = 'video'
							elsif image != null
								assign selected_media_type = 'image'
							endif
						%}
	
						{% if video != null or image != null or content != blank %}
							<div
								class="c-slider__slide s-testimonial-video__block bg-black child-cover {%- if video == null and image == null %} is-text-block{% endif %} {%- if video == null and image != null %} is-image-block{% endif %}"
								{% if video != null %}data-popup-trigger="{{ 'testimonial-' | append: forloop.index }}"{% endif %}
								{{ block.shopify_attributes }}
							>
								{% if video != null or image != null %}
									{%- render 'c-media',
										selected_media_type: selected_media_type,
										image: image,
										video: video,
										show_btns: show_btns,
										is_autoplay: is_autoplay
									-%}
								{% endif %}
								{% if content != blank %}
									<div class="s-testimonial-video__block__text bg-black cr-cream">
										<div class="s-testimonial-video__block__text__stars f-h f-j-s">
											{% for i in (1..5) %}
												{% render 'svg-icons', icon: 'star' %}
											{% endfor %}
										</div>
										<p class="s-testimonial-video__block__text__quote f-v f-j-s f-a-st">
											<q class="t-h-4">{{ content | truncate: 300, '...' }}</q>
											{% if name != blank %}
												<cite class="t-b-2">{{ name }}</cite>
											{% endif %}
										</p>
									</div>
								{% endif %}
							</div>
						{% endif %}
					{% endfor %}
				{%- endcapture -%}
	
				{%- render 'c-slider',
					classes: 's-testimonial-video__blocks',
					slider_html: slider_html,
					custom_slides_size: '--slide-size: 18%; --slide-gap: 20px;',
					slider_options: "{'loop': true, 'skipSnaps': true, 'align': 'start'}",
					is_full_width_on_mobile: true,
					enable_nav: true,
					enable_dots: true,
					enable_wheel: true
				-%}
			{%- endif -%}
	
			{%- if cta_label != blank and cta_url != blank -%}
				<a
					class="s-testimonial-video__cta btn-outline tablet-down-only"
					href="{{- cta_url -}}"
				>
					<span class="btn-outline__label">{{- cta_label -}}</span>
				</a>
			{%- endif -%}
		</div>
	
		{% comment %} POPUP CONTENT {% endcomment %}
		{% for block in media_blocks %}
			{% assign video = block.settings.video %}
			<div
				class="is-hidden"
				data-popup-target="{{ 'testimonial-' | append: forloop.index }}"
			>
				<div class="s-testimonial-video__popup">
					<button
						type="button"
						class="s-testimonial-video__popup__close cr-cream"
						data-popup-close="{{ 'testimonial-' | append: forloop.index }}"
						aria-label="Close popup"
					>
						<span class="icon-close"></span>
					</button>
					<button
						type="button"
						class="p-fill"
						data-popup-close="{{ 'testimonial-' | append: forloop.index }}"
						aria-label="Close popup"
					></button>
	
					{% render 'c-video',
						video_type: 'video',
						video: video,
						controls: false,
						is_autoplay: true,
						has_play_btn: true,
						has_mute_btn: true
					%}
				</div>
			</div>
		{% endfor %}
	{% endif %}